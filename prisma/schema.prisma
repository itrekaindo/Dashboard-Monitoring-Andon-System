model scada_line1_lantai3 {
  id               Int       @id @default(autoincrement())
  waktu_log        DateTime? @default(now()) @db.Timestamp(0)
  status_ws1       Boolean?
  status_ws2       Boolean?
  status_ws3       Boolean?
  status_ws4       Boolean?
  status_ws5       Boolean?
  timer_kerja_ws1  Int?
  timer_kerja_ws2  Int?
  timer_kerja_ws3  Int?
  timer_kerja_ws4  Int?
  timer_kerja_ws5  Int?
  timer_kuning_ws1 Int?
  timer_kuning_ws2 Int?
  timer_kuning_ws3 Int?
  timer_kuning_ws4 Int?
  timer_kuning_ws5 Int?
  timer_merah_ws1  Int?
  timer_merah_ws2  Int?
  timer_merah_ws3  Int?
  timer_merah_ws4  Int?
  timer_merah_ws5  Int?
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(GUEST)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("auth_users")
}

enum Role {
  ADMIN
  PENGENDALIAN
  PERENCANAAN
  GUEST
}
