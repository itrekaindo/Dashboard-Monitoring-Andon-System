generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model andon_line1_lantai3 {
  id                Int       @id @default(autoincrement())
  id_project        String?   @db.VarChar(50)
  id_product        String?   @db.VarChar(50)
  id_perproduct     String?   @db.VarChar(50)
  product_name      String?   @db.VarChar(50)
  timestamps        DateTime? @db.DateTime(0)
  start_actual      DateTime? @db.Date
  finish_actual     DateTime? @db.Date
  operator_assigned Int?
  operator_rfid     Int?
  workstation       Int?
  mtc_status        Int?
  operator_actual   Int?
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ideal_time {
  id            Int?
