model production_schedule {
  id                  Int       @id @default(autoincrement())
  id_project          String?   @db.VarChar(50)
  id_product          String?   @db.VarChar(50)
  mppl                DateTime? @db.Date
  month               String?   @db.VarChar(50)
  project             String?   @db.VarChar(50)
  project_client      String?   @db.VarChar(50)
  batch               Int?
  trainset            Int?
  workshop            String?   @db.VarChar(50)
