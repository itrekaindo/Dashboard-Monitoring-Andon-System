model production_progress {
  id_process           Int       @id @unique(map: "id_process") @default(autoincrement())
  id_product           String?   @db.VarChar(50)
  id_perproduct        String?   @db.VarChar(50)
  project_name         String?   @db.VarChar(50)
  product_name         String?   @db.VarChar(50)
  trainset             Int?
  line                 String?   @db.VarChar(50)
  workshop             String?   @db.VarChar(50)
  process_name         String?   @db.VarChar(50)
  workstation          Int?
  operator_actual_rfid Int?
  operator_actual_name String?   @db.VarChar(50)
  start_actual         DateTime? @db.DateTime(0)
  duration_sec_actual  Int?
  duration_time_actual DateTime? @db.Time(0)
  status               String?   @db.VarChar(50)
  finish_actual        DateTime? @db.DateTime(0)
  note_qc              String?   @db.VarChar(50)
}

